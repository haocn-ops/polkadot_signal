{
  "name": "polkadot-signal-client",
  "version": "0.2.0",
  "description": "TypeScript client for Polkadot Signal key management and AI Agent communication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./SignalKeysClient": {
      "types": "./dist/SignalKeysClient.d.ts",
      "default": "./dist/SignalKeysClient.js"
    },
    "./AgentClient": {
      "types": "./dist/AgentClient.d.ts",
      "default": "./dist/AgentClient.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "example": "ts-node src/example.ts",
    "agent-example": "ts-node src/agent_example.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "keywords": [
    "polkadot",
    "signal",
    "e2ee",
    "messaging",
    "blockchain",
    "ai-agent",
    "agent-communication"
  ],
  "author": "Polkadot Signal Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@polkadot/api": "^10.9.1",
    "@polkadot/keyring": "^12.3.2",
    "@polkadot/types": "^10.9.1",
    "@polkadot/util": "^12.3.2",
    "@polkadot/util-crypto": "^12.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "ts-jest": "^29.1.1"
  }
}
